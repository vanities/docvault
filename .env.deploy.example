# Env vars passed by `make deploy` into the DocVault container on NAS.
# Copy this file to `.env.deploy` (gitignored) and fill in real values.
# The Makefile's `restart` target sources `.env.deploy` and passes these
# through as -e flags when running `docker run` on the NAS.

# Master encryption key for sensitive settings fields (API keys, exchange
# secrets, backup password). REQUIRED — container won't start without it.
# Generate with: openssl rand -base64 32
DOCVAULT_MASTER_KEY=

# Optional: username + password for DocVault login. Leave both blank to
# disable auth (LAN-only use). Both must be set to enable login.
DOCVAULT_USERNAME=
DOCVAULT_PASSWORD=

# Optional: OAuth bearer token for Claude.ai subscription. Used by the chat
# route's @anthropic-ai/claude-agent-sdk to authenticate against Claude Code's
# rate-limit pool (instead of paying API per-token). Generate on a Mac with
# Claude Code logged in: `claude setup-token`. Leave blank to fall back to
# the Anthropic API key configured in DocVault Settings.
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: LAN Check the Vote service bridge. Keep the API key server-side;
# `make deploy` passes it only into the backend container.
CHECKTHEVOTE_BASE_URL=
CHECKTHEVOTE_API_KEY=
