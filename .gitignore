# Apple Health export fixtures — contain personal medical data, never commit
server/parsers/fixtures/
**/apple-health-fixture*.zip
**/export.zip
**/apple_health_export/

# Scripts that reference NAS/personal data
scripts/*
# Exceptions: scripts shipped in the Docker image. Using `scripts/*` (not
# `scripts/`) because gitignore can't re-include files inside an excluded
# directory — matching contents lets the !-rules below take effect.
!scripts/sync-to-dropbox.sh
!scripts/docker-entrypoint.sh
# Exception: skill helper scripts are sanitized and meant to be public
!skills/*/scripts/
!skills/*/scripts/**

# All test files (may contain personal financial data)
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
# Exception: Politics dashboard tests use synthetic congressional payloads, no personal data
!src/components/Politics/politicsData.test.ts
# Exception: quant math tests are pure computation, no personal data
!server/routes/quant.test.ts
# Exception: crypto-keys tests are pure crypto primitives, no personal data
!server/crypto-keys.test.ts
# Exception: backup tests use synthetic tmpdir fixtures, no personal data
!server/backup.test.ts
# Exception: dna-traits tests use synthetic SNP fixtures, no personal genomic data
!server/parsers/dna-traits.test.ts
# Exception: apple-health clinical parser tests use fabricated FHIR fixtures, no personal data
!server/parsers/apple-health-clinical.test.ts
# Exception: kraken reconcile tests are pure merge logic with fabricated figures, no personal data
!server/crypto-kraken-reconcile.test.ts
# Exception: manual-holdings tests are pure pricing/shaping logic with fabricated figures, no personal data
!server/crypto-manual-holdings.test.ts
# Exception: example-job seeding test uses synthetic tmpdir fixtures, no personal data
!server/seed-example-jobs.test.ts
# Exception: external-sources tests are generic git/url/sync logic with fabricated fixtures, no personal data
!server/external-sources.test.ts
# Exception: pdf-forms tests build fabricated fillable PDFs in-memory, no personal data
!server/pdf-forms.test.ts
# Exception: prediction-market normalization tests use synthetic Kalshi/Polymarket payloads, no personal data
!server/prediction-markets.test.ts
# Exception: chat-threads store tests use fabricated thread fixtures in a tmpdir, no personal data
!server/chat-threads-store.test.ts
# Exception: politics ingest tests use synthetic/public congressional payloads, no personal data
!server/politics/feed.test.ts
!server/politics/scanned-house-ptr.test.ts
!server/politics/clusters.test.ts
!server/politics/option-description.test.ts
!server/politics/filing-archive.test.ts
!server/politics/backtest.test.ts
# Exception: amortization math tests are pure computation, no personal data
!src/utils/amortization.test.ts
# Exception: daily-news schedule/report/digest tests use pure date math and fabricated edition HTML/data, no personal data
!server/daily-news-schedule.test.ts
!server/daily-news-report.test.ts
!server/daily-news.test.ts

